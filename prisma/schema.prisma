generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id          String   @id @default(cuid())
  name        String   @unique
  safetyScore Int
  benefits    String
  risks       String
  category    String?

  createdAt   DateTime @default(now())
}

model SearchHistory {
  id        String   @id @default(cuid())
  input     String
  score     Int
  createdAt DateTime @default(now())
}